# PolyClaw Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Polymarket API (public endpoints work without keys for basic market data)
# =============================================================================
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=

# =============================================================================
# Binance (public WebSocket works without keys for price feeds)
# Keys needed only for authenticated endpoints
# =============================================================================
BINANCE_API_KEY=
BINANCE_API_SECRET=

# =============================================================================
# Polygon (Matic) Chain - for on-chain wallet analysis
# Get free key at https://polygonscan.com/apis
# =============================================================================
POLYGONSCAN_API_KEY=

# =============================================================================
# Kalshi Exchange (CFTC-regulated prediction markets)
# Get API keys at https://kalshi.com → Account & Security → API Keys
# Demo environment: https://demo.kalshi.co (separate credentials)
# =============================================================================
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
# Set to "true" for demo, "false" for production (default: true for safety)
KALSHI_DEMO=true

# =============================================================================
# Simulator Settings
# =============================================================================
PAPER_TRADE_STARTING_BALANCE=1000
PAPER_TRADE_MAX_POSITION_PCT=0.08
PAPER_TRADE_DAILY_LOSS_LIMIT_PCT=0.20
PAPER_TRADE_KILL_SWITCH_PCT=0.40

# =============================================================================
# Data Storage
# =============================================================================
DATABASE_PATH=polyclaw_data.db
LOG_LEVEL=INFO

# =============================================================================
# Supabase (shared database — PolyClaw tables prefixed with polyclaw_)
# Dashboard: https://supabase.com/dashboard
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
